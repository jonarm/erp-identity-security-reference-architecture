{
  "displayName": "CA006 - MCAS Session Control for Unmanaged Devices",
  "state": "enabled",
  "conditions": {
    "users": {
      "includeUsers": ["All"],
      "excludeUsers": [],
      "excludeGroups": []
    },
    "applications": {
      "includeApplications": ["All"]
    },
    "clientAppTypes": ["all"],
    "devices": {
      "deviceFilter": {
        "mode": "exclude",
        "rule": "device.isCompliant -eq True -or device.trustType -eq \"ServerAD\""
      }
    }
  },
  "grantControls": {
    "operator": "OR",
    "builtInControls": ["mfa"]
  },
  "sessionControls": {
    "cloudAppSecurity": {
      "cloudAppSecurityType": "mcasConfigured",
      "isEnabled": true
    }
  }
}